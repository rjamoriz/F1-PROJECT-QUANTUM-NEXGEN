# Q-AERO Production Environment Configuration
# Copy to .env.production and replace all ${SECRET_*} placeholders with actual secrets
# Use Kubernetes secrets manager or HashiCorp Vault in real production

# ============================================================================
# CRITICAL SECURITY - USE SECRET MANAGER IN PRODUCTION
# ============================================================================
JWT_SECRET=${SECRET_JWT_SECRET}
REFRESH_TOKEN_PEPPER=${SECRET_REFRESH_TOKEN_PEPPER}
MONGODB_URI=${SECRET_MONGODB_URI}
REDIS_PASSWORD=${SECRET_REDIS_PASSWORD}
NATS_USER=${SECRET_NATS_USER}
NATS_PASS=${SECRET_NATS_PASS}

# ============================================================================
# ENVIRONMENT & RUNTIME
# ============================================================================
NODE_ENV=production
LOG_LEVEL=warn
DEBUG=false
REQUIRE_DATABASE=true
REQUIRE_REDIS=true

# ============================================================================
# PUBLIC ENDPOINTS (Production domains)
# ============================================================================
BACKEND_PUBLIC_URL=https://api.qaero.f1.com
CORS_ALLOWED_ORIGINS=https://dashboard.qaero.f1.com,https://app.qaero.f1.com

# ============================================================================
# SERVICE MESH (Kubernetes internal DNS)
# ============================================================================
REDIS_URL=redis://:${SECRET_REDIS_PASSWORD}@redis-service.qaero.svc.cluster.local:6379
NATS_URL=nats://${SECRET_NATS_USER}:${SECRET_NATS_PASS}@nats-service.qaero.svc.cluster.local:4222
PHYSICS_SERVICE_URL=http://physics-service.qaero.svc.cluster.local:8001
ML_SERVICE_URL=http://ml-service.qaero.svc.cluster.local:8000
QUANTUM_SERVICE_URL=http://quantum-service.qaero.svc.cluster.local:8002
RL_TRAINING_SERVICE_URL=http://ml-service.qaero.svc.cluster.local:8000
RL_TRAINING_SUBMIT_ENDPOINT=/api/v1/rl/train
RL_TRAINING_STATUS_ENDPOINT=/api/v1/rl/jobs/:job_id

# Frontend build-time wiring
NEXT_PUBLIC_BACKEND_URL=https://api.qaero.f1.com
NEXT_PUBLIC_BACKEND_WS_URL=wss://api.qaero.f1.com
NEXT_PUBLIC_AUTH_AUTO_REFRESH=true

# ============================================================================
# FEATURE FLAGS & SECURITY
# ============================================================================
ENABLE_RATE_LIMIT=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=50
AUTH_REQUIRE_SESSION=true
EVOLUTION_HTTP_AUTH_REQUIRED=true
EVOLUTION_WS_AUTH_REQUIRED=trstrict

# ============================================================================
# OBSERVABILITY & MONITORING
# ============================================================================
OBS_ENV_PROFILE=production
APM_ENABLED=true
APM_SERVICE_NAME=qaero-backend-prod
METRICS_ENABLED=true
TRACING_ENABLED=trueION_MODE=normal
# ============================================================================
# SLO TARGETS (Production: 99.9% availability)
# ============================================================================
SLO_TARGET_AVAILABILITY=99.9
SLO_ERROR_BUDGET_PERCENT=0.1
SLO_WS_DROP_RATE_TARGET=1.0

# ============================================================================
# SERVICE TIMEOUTS & RESILIENCE
# ============================================================================
SERVICE_TIMEOUT_MS=45000
OBS_MAX_WS_SAMPLES=6000
OBS_CALIBRATION_LOOKBACK_MS=3600000

# ============================================================================
# QUANTUM OPTIMIZATION (Production settings)
# ============================================================================
QUANTUM_METHOD=auto
QUANTUM_TIMEOUT_MS=45000
QUANTUM_MAX_QUBITS=12
QUANTUM_FALLBACK_TO_CLASSICAL=true
OBS_CALIBRATION_BUCKET_MS=60000
OBS_CALIBRATION_MIN_BUCKETS=10
ALERT_WS_RATE_LIMITED_COUNT=40
ALERT_WS_UNAUTHORIZED_SUBSCRIPTION_COUNT=20
ALERT_WS_REJECTED_CONNECTION_COUNT=20
SLO_WS_DROP_RATE_TARGET=2
RL_TRAINING_TIMEOUT_MS=30000
RL_TRAINING_SYNC_INTERVAL_MS=5000
RL_TRAINING_SUBMIT_MAX_RETRIES=2
RL_TRAINING_SYNC_MAX_RETRIES=1
RL_TRAINING_RETRY_BACKOFF_MS=600
RL_TRAINING_CIRCUIT_BREAKER_FAILURE_THRESHOLD=4
RL_TRAINING_CIRCUIT_BREAKER_COOLDOWN_MS=120000
RL_TRAINING_ALLOW_SYNTHETIC_FALLBACK=false
RL_DEPLOY_MIN_STABILITY_SCORE=0.75
RL_DEPLOY_MIN_MEAN_EPISODE_REWARD=1.0
RL_DEPLOY_MIN_LAP_TIME_GAIN_MS=1.5
RL_DEPLOY_MAX_SYNC_FAILURES=3
QUANTUM_RELIABILITY_WINDOW_MS=3600000
QUANTUM_RELIABILITY_MAX_SAMPLES=6000
QUANTUM_RELIABILITY_MEMORY_MAX_SAMPLES=6000
QUANTUM_RELIABILITY_RETENTION_MS=604800000
QUANTUM_RELIABILITY_INGEST_MAX_BATCH=500
QUANTUM_RELIABILITY_INGEST_REQUIRE_TOKEN=true
# QUANTUM_RELIABILITY_INGEST_TOKEN=replace-with-secure-ingest-token
QUANTUM_RELIABILITY_INGEST_ALLOWED_SOURCES=external-ingest,hardware-collector,provider-collector
QUANTUM_RELIABILITY_LIVE_SOURCE_TAGS=external-ingest,hardware-collector,provider-collector
QUANTUM_CALIBRATION_LOOKBACK_MS=3600000
QUANTUM_CALIBRATION_BUCKET_MS=60000
QUANTUM_CALIBRATION_MIN_BUCKETS=8
QUANTUM_ALERT_VQE_QUEUE_LENGTH=20
QUANTUM_ALERT_DWAVE_QUEUE_LENGTH=25
QUANTUM_ALERT_VQE_ERROR_RATE_PERCENT=1.2
QUANTUM_ALERT_DWAVE_ERROR_RATE_PERCENT=1.6
QUANTUM_SLO_PROVIDER_AVAILABILITY_TARGET=99
QUANTUM_CALIBRATION_APPROVAL_MIN_CONFIDENCE=medium
QUANTUM_ROLLOUT_MIN_CONFIDENCE=medium
QUANTUM_ROLLOUT_ALLOW_FALLBACK_SOURCE=false
QUANTUM_ROLLOUT_MIN_SIGNAL_BUCKETS=8
QUANTUM_ROLLOUT_REQUIRE_LIVE_SOURCE=true
QUANTUM_ROLLOUT_MIN_LIVE_SIGNAL_BUCKETS=8
QUANTUM_ROLLOUT_REQUIRE_RECENT_SAMPLES=true
QUANTUM_ROLLOUT_MAX_SAMPLE_AGE_MS=900000
QUANTUM_ROLLOUT_ENFORCE_AVAILABILITY_TARGET=true
QUANTUM_ROLLOUT_MAX_FALLBACK_RATIO_PERCENT=35
QUANTUM_ROLLOUT_REQUIRE_PERSISTED_STORE=false
QUANTUM_RELIABILITY_SOURCE_STATUS_STALE_MS=900000
QUANTUM_RELIABILITY_COLLECTOR_SOURCE=provider-collector-prod
# QUANTUM_RELIABILITY_COLLECTOR_SOURCE_BY_ENV=prod:provider-collector-prod
QUANTUM_RELIABILITY_COLLECTOR_MODE=status+optimize
QUANTUM_RELIABILITY_COLLECTOR_INTERVAL_SECONDS=30
QUANTUM_RELIABILITY_COLLECTOR_MAX_ITERATIONS=0
QUANTUM_RELIABILITY_COLLECTOR_DURATION_SECONDS=0
QUANTUM_RELIABILITY_COLLECTOR_ALLOW_FALLBACK=false
QUANTUM_RELIABILITY_COLLECTOR_FAIL_ON_INGEST_ERROR=true
QUANTUM_RELIABILITY_COLLECTOR_VQE_NUM_VARIABLES=20
QUANTUM_RELIABILITY_COLLECTOR_DWAVE_NUM_ELEMENTS=40
QUANTUM_RELIABILITY_COLLECTOR_DWAVE_NUM_READS=900
QUANTUM_RELIABILITY_COLLECTOR_TARGET_CL=2.8
QUANTUM_RELIABILITY_COLLECTOR_TARGET_CD=0.4
QUANTUM_ROLLOUT_SIGNOFF_ENVIRONMENTS=staging,prod
QUANTUM_ROLLOUT_SIGNOFF_INCLUDE_CALIBRATION=true
QUANTUM_ROLLOUT_SIGNOFF_PERSIST_RESULTS=true
QUANTUM_ROLLOUT_SIGNOFF_FAIL_ON_BLOCKED=true
QUANTUM_ROLLOUT_SIGNOFF_RETENTION_MS=2592000000
QUANTUM_ROLLOUT_SIGNOFF_MEMORY_MAX_RECORDS=4000
OBS_INCIDENT_AUTOMATION_ENABLED=true
# OBS_INCIDENT_AUTOMATION_TOKEN=set-only-if-you-need-token-guarded-automation
OBS_ACTION_EXEC_TIMEOUT_MS=15000
OBS_ACTION_EXEC_MAX_OUTPUT_BYTES=8192
OBS_ACTION_POLICY_MODE=locked
OBS_ACTION_REQUIRE_ABSOLUTE_PATH=true
# OBS_ACTION_ALLOWED_BINARIES=["/usr/local/bin/qaero-scale-out","/usr/local/bin/qaero-rollback"]
# OBS_ACTION_SCALE_OUT_CMD=["/usr/local/bin/qaero-scale-out","--service","backend"]
# OBS_ACTION_ROLLBACK_CMD=["/usr/local/bin/qaero-rollback","--to","previous-stable"]
