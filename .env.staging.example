# Q-AERO Staging Environment Configuration
# Copy to .env.staging and fill in actual secrets

# Environment
NODE_ENV=staging
DEBUG=false

# API Configuration
PORT=3001
BACKEND_URL=http://staging-backend:3001
NEXT_PUBLIC_API_URL=http://staging.qaero.local:3001

# Security (REPLACE WITH ACTUAL SECRETS)
JWT_SECRET=staging-jwt-secret-change-me-256-bits-minimum
REFRESH_TOKEN_PEPPER=staging-pepper-change-me-256-bits
SESSION_SECRET=staging-session-change-me

# Database
MONGODB_URI=mongodb://mongodb:27017/qaero_staging
REQUIRE_DATABASE=true
MONGODB_OPTIONS={"maxPoolSize":50,"minPoolSize":10}

# Redis
REDIS_URL=redis://redis:6379/1
REDIS_TTL_SECONDS=3600

# NATS
NATS_URL=nats://nats:4222

# Service URLs (Internal Docker Network)
ML_SERVICE_URL=http://ml-surrogate:8000
PHYSICS_SERVICE_URL=http://physics-engine:8001
QUANTUM_SERVICE_URL=http://quantum-optimizer:8002

# Feature Flags
ENABLE_RATE_LIMIT=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
EVOLUTION_WS_AUTH_REQUIRED=true

# Quantum Configuration
QUANTUM_TIMEOUT_MS=30000
QUANTUM_DEFAULT_METHOD=auto
QUANTUM_MAX_QUBITS=12

# ML Configuration
ML_TIMEOUT_MS=10000
ML_BATCH_SIZE=64

# Physics Configuration
PHYSICS_TIMEOUT_MS=15000
VLM_CACHE_ENABLED=true

# Observability
LOG_LEVEL=info
LOG_FORMAT=json
ENABLE_REQUEST_LOGGING=true

# SLO Configuration
SLO_ERROR_BUDGET_PERCENT=5.0
SLO_TARGET_AVAILABILITY=99.5

# CORS
CORS_ORIGINS=http://staging.qaero.local:3000,http://localhost:3000

# Health Check
HEALTH_CHECK_INTERVAL_MS=5000
