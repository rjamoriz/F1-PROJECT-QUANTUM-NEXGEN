# Backend API Gateway Environment Variables

# Server Configuration
PORT=3001
NODE_ENV=development
LOG_LEVEL=info
REQUEST_BODY_LIMIT=10mb
BACKEND_PUBLIC_URL=http://localhost:3001

# Database
MONGODB_URI=mongodb://mongodb:27017/qaero
REQUIRE_DATABASE=true

# Redis Cache
REDIS_URL=redis://redis:6379
REQUIRE_REDIS=false

# Microservices URLs
PHYSICS_SERVICE_URL=http://physics-engine:8001
ML_SERVICE_URL=http://ml-surrogate:8000
QUANTUM_SERVICE_URL=http://quantum-optimizer:8002
CFD_ENGINE=mock
# CFD_SERVICE_URL=http://cfd-service:9000
# CFD_TIMEOUT_MS=45000

# GenAI Agents
NATS_URL=nats://nats:4222

# Security
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=24h

# Rate Limiting
ENABLE_RATE_LIMIT=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=300

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000
CORS_ALLOW_CREDENTIALS=false
